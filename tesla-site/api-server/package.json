    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "nodemailer": "^6.9.15",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "uuid": "^10.0.0",
    "@supabase/supabase-js": "^2.47.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.16",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.24.0",
    "pino-pretty": "^11.0.0",
    "typescript": "~5.6.0"
  }
